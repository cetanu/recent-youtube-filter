{
  "manifest_version": 2,
  "name": "Recent YouTube Filter",
  "version": "0.1.1",
  "description": "Removes YouTube feed videos that were posted more than a configured number of days ago.",
  "permissions": [
    "storage",
    "*://www.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/*"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "src/options.html",
    "browser_style": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "recent-youtube-filter@example.local",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
